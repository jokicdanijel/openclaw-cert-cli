# OpenClaw Master-Zertifizierungs-CLI — Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine Werte ein.
# Die .env Datei wird NICHT ins Git-Repository eingecheckt.

# ── Pflicht ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-dein-api-key-hier

# ── Optional ─────────────────────────────────────────────────────────────────
# KI-Modell (Standard: gpt-4o)
OPENCLAW_MODEL=gpt-4o

# Debug-Logging aktivieren (true/false) — alternativ: --debug CLI-Flag
OPENCLAW_DEBUG=false
