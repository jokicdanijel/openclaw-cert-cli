# Kopiere diese Datei nach .env:
#   cp .env.example .env

# OpenAI API Key (PFLICHT)
OPENAI_API_KEY="sk-proj-..."

# KI-Modell (Standard: gpt-4o)
OPENCLAW_MODEL=gpt-4o

# Debug-Logging aktivieren — alternativ: --debug CLI-Flag
OPENCLAW_DEBUG=false
